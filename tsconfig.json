{
  "compilerOptions": {
    "declaration": true,
    "sourceMap": true,
    "removeComments": false,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "outDir": "./dist",
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitThis": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
  },
  "files": ["shims.d.ts"],
  "include": [
    "src/",
    "eslint.config.ts",
    "prettier.config.mjs",
    "jest.config.ts"
  ]
}
