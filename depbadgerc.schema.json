{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/depbadge.schema.json",
  "title": "DepbadgeRC",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest", "dependencies"],

  "properties": {
    "integrity": { "type": "string" },
    "target": { "type": "string" },
    "manifest": { "type": "string" },

    "output": {
      "type": "array",
      "items": { "$ref": "#/$defs/OutputFormat" },
      "uniqueItems": true
    },

    "dependenciesLayout": { "$ref": "#/$defs/Layout" },
    "devDependenciesLayout": { "$ref": "#/$defs/Layout" },
    "peerDependenciesLayout": { "$ref": "#/$defs/Layout" },
    "statusBadgesLayout": { "$ref": "#/$defs/Layout" },

    "dependenciesStyle": { "$ref": "#/$defs/BadgeStyle" },
    "devDependenciesStyle": { "$ref": "#/$defs/BadgeStyle" },
    "peerDependenciesStyle": { "$ref": "#/$defs/BadgeStyle" },
    "statusBadgesStyle": { "$ref": "#/$defs/BadgeStyle" },

    "dependencies": { "$ref": "#/$defs/Dependencies" },
    "devDependencies": { "$ref": "#/$defs/Dependencies" },
    "peerDependencies": { "$ref": "#/$defs/Dependencies" },
    "statusBadges": { "$ref": "#/$defs/StatusBadges" }
  },

  "$defs": {
    "Theme": {
      "type": "string",
      "enum": ["dark", "white"]
    },

    "Position": {
      "type": "string",
      "enum": ["left", "right", "center", "justify"]
    },

    "OutputFormat": {
      "type": "string",
      "enum": ["json", "markdown"]
    },

    "BadgeStyle": {
      "type": "object",
      "properties": {
        "color": { "type": "string" },
        "labelColor": { "type": "string" },
        "isError": { "type": "boolean" },
        "namedLogo": { "type": "string" },
        "logoSvg": { "type": "string" },
        "logoColor": { "type": "string" },
        "logoWidth": { "type": "number" },
        "style": { "type": "string" },
        "cacheSeconds": { "type": "number" },
        "link": { "type": "string" }
      }
    },

    "Layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": { "$ref": "#/$defs/Theme" },
        "header": { "type": "string" },
        "showHeader": { "type": "boolean" },
        "position": { "$ref": "#/$defs/Position" }
      }
    },

    "DependencyItem": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "message": { "type": "string" },

        "color": { "type": "string" },
        "labelColor": { "type": "string" },
        "isError": { "type": "boolean" },
        "namedLogo": { "type": "string" },
        "logoSvg": { "type": "string" },
        "logoColor": { "type": "string" },
        "logoWidth": { "type": "number" },
        "style": { "type": "string" },
        "cacheSeconds": { "type": "number" },
        "link": { "type": "string" }
      }
    },

    "Dependencies": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "layout": { "$ref": "#/$defs/Layout" },
        "badgeStyle": { "$ref": "#/$defs/BadgeStyle" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/DependencyItem" }
        }
      }
    },

    "GitHubStatusBadge": {
      "type": "object",
      "required": ["name", "metric", "user", "repo"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "github" },
        "metric": {
          "type": "string",
          "enum": ["stars", "license", "release"]
        },
        "user": { "type": "string" },
        "repo": { "type": "string" },
        "branch": { "type": ["string", "null"] },

        "message": { "type": "string" },

        "color": { "type": "string" },
        "labelColor": { "type": "string" },
        "isError": { "type": "boolean" },
        "namedLogo": { "type": "string" },
        "logoSvg": { "type": "string" },
        "logoColor": { "type": "string" },
        "logoWidth": { "type": "number" },
        "style": { "type": "string" },
        "cacheSeconds": { "type": "number" },
        "link": { "type": "string" }
      }
    },

    "DockerHubStatusBadge": {
      "type": "object",
      "required": ["name", "metric", "user", "image"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "docker" },
        "metric": {
          "type": "string",
          "enum": ["pulls", "stars", "v"]
        },
        "user": { "type": "string" },
        "image": { "type": "string" },
        "tag": { "type": ["string", "null"] },

        "message": { "type": "string" },

        "color": { "type": "string" },
        "labelColor": { "type": "string" },
        "isError": { "type": "boolean" },
        "namedLogo": { "type": "string" },
        "logoSvg": { "type": "string" },
        "logoColor": { "type": "string" },
        "logoWidth": { "type": "number" },
        "style": { "type": "string" },
        "cacheSeconds": { "type": "number" },
        "link": { "type": "string" }
      }
    },

    "CodecovStatusBadge": {
      "type": "object",
      "required": ["name", "user", "repo"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "codecov" },
        "user": { "type": "string" },
        "repo": { "type": "string" },
        "branch": { "type": "string" },
        "flag": { "type": ["string", "null"] },

        "message": { "type": "string" },

        "color": { "type": "string" },
        "labelColor": { "type": "string" },
        "isError": { "type": "boolean" },
        "namedLogo": { "type": "string" },
        "logoSvg": { "type": "string" },
        "logoColor": { "type": "string" },
        "logoWidth": { "type": "number" },
        "style": { "type": "string" },
        "cacheSeconds": { "type": "number" },
        "link": { "type": "string" }
      }
    },

    "StatusBadgeItem": {
      "oneOf": [
        { "$ref": "#/$defs/GitHubStatusBadge" },
        { "$ref": "#/$defs/DockerHubStatusBadge" },
        { "$ref": "#/$defs/CodecovStatusBadge" }
      ]
    },

    "StatusBadges": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "layout": { "$ref": "#/$defs/Layout" },
        "badgeStyle": { "$ref": "#/$defs/BadgeStyle" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/StatusBadgeItem" }
        }
      }
    }
  }
}
